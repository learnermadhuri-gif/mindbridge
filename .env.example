# Copy this file to .env and fill in your values.

# Option A: Use a Gemini API key (easiest for local development and competition demos).
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Option B: Use Google Cloud Vertex AI (requires gcloud auth login --update-adc).
# Uncomment and set these if you prefer Vertex AI:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-east1
# GOOGLE_GENAI_USE_VERTEXAI=True
